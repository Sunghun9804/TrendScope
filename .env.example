# Required MySQL settings
MBC_DB_HOST=localhost
MBC_DB_PORT=3306
MBC_DB_NAME=trendscope
MBC_DB_USER=your_db_user
MBC_DB_PASSWORD=your_db_password_here

# Required Elasticsearch setting
MBC_ES_URL=http://localhost:9200

# Required app secret
MBC_SESSION_SECRET_KEY=replace_with_a_random_32_plus_char_secret

# Optional external API
GEMINI_API_KEY=

# Optional tuning
# MBC_DB_ECHO=true
# MBC_DB_POOL_SIZE=100
# MBC_DB_POOL_MAX_OVERFLOW=20
# MBC_DB_POOL_TIMEOUT=30
# MBC_ES_CONNECTIONS_PER_NODE=10
# MBC_ES_REQUEST_TIMEOUT=120
